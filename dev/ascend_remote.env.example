# Remote ssh target. Your current setup already uses this alias.
ASCEND_REMOTE_HOST=ascend-dev

# Remote repository path on host.
ASCEND_REMOTE_REPO=/docker/tf/ops-transformer

# Container used for build/test.
ASCEND_REMOTE_CONTAINER=tf

# Repository path inside container. Default is the same as host path.
ASCEND_REMOTE_CONTAINER_REPO=/docker/tf/ops-transformer

# Remote directory used to store run logs.
ASCEND_REMOTE_LOG_ROOT=/docker/tf/ops-transformer/.codex-remote-logs

# Local directory used to pull remote logs.
ASCEND_LOCAL_LOG_ROOT=.codex-remote-logs

# Optional environment bootstrap command that runs inside container before build/test.
# Example:
# ASCEND_CONTAINER_ENV_CMD="source /usr/local/Ascend/cann/set_env.sh"
ASCEND_CONTAINER_ENV_CMD=

# Optional defaults; can be overridden by --build-cmd / --test-cmd.
ASCEND_BUILD_CMD=
ASCEND_TEST_CMD=
